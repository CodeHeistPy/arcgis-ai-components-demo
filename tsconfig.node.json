{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "./.tsbuild-node",
    "tsBuildInfoFile": "./.tsbuild-node/tsconfig.node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
