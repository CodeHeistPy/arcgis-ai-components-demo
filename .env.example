# Copy to `.env.local` (gitignored) and fill in your own values.

# OAuth client ID from a Developer credentials item in YOUR ArcGIS Online org.
# Use OAuth 2.0 *User authentication* (not app auth). Add http://localhost:5173
# as a redirect URI on that item. You need only the Client ID — no secret.
VITE_ARCGIS_OAUTH_APP_ID=

# Portal URL the app signs in against (used for esriConfig.portalUrl AND
# OAuthInfo.portalUrl). This is the SAML-vs-built-in lever — see ACTIVITY-2-AUTH.md:
#   - https://www.arcgis.com            → generic ArcGIS sign-in. Works for both
#                                         account types; SAML users pick their org
#                                         / enterprise login first.
#   - https://<your-org-key>.maps.arcgis.com → targets your org directly; routes
#                                         SAML members to your identity provider.
#                                         Cleanest for orgs that use SAML logins.
# Built-in vs SAML use the SAME OAuth 2.0 flow and the SAME app code — only this
# value changes the experience.
VITE_PORTAL_URL=https://www.arcgis.com

# Your web map's item ID. This is what <arcgis-map item-id="..."> loads and what
# the OOB agents discover the feature layer through. The web map MUST have AI
# vector embeddings generated (Item Details → Settings in AGO) or the assistant
# errors with "Embeddings not found for this web map."
VITE_WEBMAP_ID=REPLACE_WITH_YOUR_WEBMAP_ITEM_ID

# Direct feature service URL. Phase 1 does NOT need this — only the Phase 2
# custom agent uses it for direct FeatureLayer queries. Format example:
# https://services.arcgis.com/<YOUR_ORG_ID>/arcgis/rest/services/<YOUR_SERVICE_NAME>/FeatureServer/0
VITE_FEATURE_SERVICE_URL=
